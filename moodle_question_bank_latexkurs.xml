  <question type="multichoice">
    <name><text>Workflow_Grundidee</text></name>
    <questiontext format="html"><text><![CDATA[<p>Was ist die Grundidee des LaTeX-Workflows laut Kurs?</p>]]></text></questiontext>
    <defaultgrade>1.0000000</defaultgrade><penalty>0.3333333</penalty><hidden>0</hidden>
    <single>true</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
    <answer fraction="100"><text>Quelltext schreiben statt Direktformatierung</text><feedback format="html"><text><![CDATA[<p>Genau: Inhalt/Struktur im Quelltext, Satz durch LaTeX.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Layout manuell in jeder Zeile steuern</text><feedback format="html"><text><![CDATA[<p>Das widerspricht dem Ansatz.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Nur PDF nachträglich bearbeiten</text><feedback format="html"><text><![CDATA[<p>Nicht der empfohlene Weg.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Direkt in PowerPoint setzen</text><feedback format="html"><text><![CDATA[<p>Das ist kein LaTeX-Workflow.</p>]]></text></feedback></answer>
  </question>

  <question type="multichoice">
    <name><text>Workflow_Projektstruktur</text></name>
    <questiontext format="html"><text><![CDATA[<p>Welche Struktur ist im Kurs als sinnvoll beschrieben?</p>]]></text></questiontext>
    <defaultgrade>1.0000000</defaultgrade><penalty>0.3333333</penalty><hidden>0</hidden>
    <single>true</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
    <answer fraction="100"><text>Hauptdatei plus Kapiteldateien und geordnete Unterordner</text><feedback format="html"><text><![CDATA[<p>Richtig: modulare Dateistruktur.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Alles in einer einzigen riesigen .tex-Datei</text><feedback format="html"><text><![CDATA[<p>Unübersichtlich und nicht empfohlen.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Nur Binärdateien ohne Quelltext</text><feedback format="html"><text><![CDATA[<p>Quelltext ist zentral.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Keine Ordner, nur Desktop-Dateien</text><feedback format="html"><text><![CDATA[<p>Nicht reproduzierbar/übersichtlich.</p>]]></text></feedback></answer>
  </question>

