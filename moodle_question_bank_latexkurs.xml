  <question type="multichoice">
    <name><text>Figure_EPS_PdfLatex</text></name>
    <questiontext format="html"><text><![CDATA[<p>Welche Aussage zu <code>.eps</code> und <code>pdflatex</code> ist korrekt?</p>]]></text></questiontext>
