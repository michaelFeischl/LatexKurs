  <question type="multichoice">
    <name><text>Intro_Setups</text></name>
    <questiontext format="html"><text><![CDATA[<p>Welche zwei Arbeitsweisen werden im Kurs explizit genannt?</p>]]></text></questiontext>
    <defaultgrade>1.0000000</defaultgrade><penalty>0.3333333</penalty><hidden>0</hidden>
    <single>true</single><shuffleanswers>true</shuffleanswers><answernumbering>abc</answernumbering>
    <answer fraction="100"><text>Lokal mit TeX-Distribution und online mit Overleaf</text><feedback format="html"><text><![CDATA[<p>Genau das sind die beiden Setups im Kurs.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Nur handschriftliche Formeln und Word-Export</text><feedback format="html"><text><![CDATA[<p>Das gehört nicht zum Kursworkflow.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Nur Overleaf, ohne lokale Option</text><feedback format="html"><text><![CDATA[<p>Lokales Arbeiten ist ebenfalls Teil des Kurses.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>Nur LaTeX im Browser ohne Dateien</text><feedback format="html"><text><![CDATA[<p>Dateibasierte Arbeit ist zentral.</p>]]></text></feedback></answer>
  </question>

  <question type="truefalse">
    <name><text>Intro_Lernziel</text></name>
    <questiontext format="html"><text><![CDATA[<p>Ein Lernziel ist, reproduzierbare PDF-Ergebnisse aus Quelltext zu erzeugen.</p>]]></text></questiontext>
    <defaultgrade>1.0000000</defaultgrade><penalty>1.0000000</penalty><hidden>0</hidden>
    <answer fraction="100"><text>true</text><feedback format="html"><text><![CDATA[<p>Richtig, reproduzierbarer Satz ist ein Kernziel.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>false</text><feedback format="html"><text><![CDATA[<p>Falsch, genau das ist ein zentrales Kursziel.</p>]]></text></feedback></answer>
  </question>

