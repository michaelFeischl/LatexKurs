    <answer fraction="0"><text>\left( x \right)</text><feedback format="html"><text><![CDATA[<p>Das sind runde Klammern, keine Norm.</p>]]></text></feedback></answer>
    <answer fraction="0"><text>\norm{x}</text><feedback format="html"><text><![CDATA[<p>Nur mit eigenem Makro definiert.</p>]]></text></feedback></answer>
